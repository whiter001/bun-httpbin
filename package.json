{
  "name": "bun-httpbin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --tsconfig tsconfig.json",
    "start": "bun run src/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "element-plus": "^2.13.7",
    "vue": "^3.5.32"
  }
}
